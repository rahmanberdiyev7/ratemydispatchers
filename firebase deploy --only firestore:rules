rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(data) { return signedIn() && request.auth.uid == data.createdBy; }

    match /dispatchers/{dispatcherId} {
      allow read: if true;

      // Only logged-in users can create, AND createdBy must equal auth.uid
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.company is string
        && request.resource.data.verified == false;

      // Only owner can update, and cannot change ownership/createdAt
      allow update: if isOwner(resource.data)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;

      // Only logged-in users can create, AND createdBy must equal auth.uid
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.dispatcherId is string
        && request.resource.data.comment is string
        && request.resource.data.rating in [1,2,3,4,5];

      allow update, delete: if false;
    }
  }
}
